<launch>

    <arg name="world" default="$(find uav_gazebo)/world/uav_simulation.world"/>

    <include file="$(find px4)/launch/posix_sitl.launch">

        <arg name="world" value="$(arg world)" />
        <arg name="sdf" value="$(find uav_gazebo)/model/iris_lightweight/iris.sdf"/>
    </include>
	
</launch>
